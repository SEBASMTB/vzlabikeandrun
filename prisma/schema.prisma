generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  description     String
  date            DateTime
  location        String
  distance        String
  category        String          @default("running")
  sportType       String          @default("running")
  imageUrl        String          @default("")
  bannerImage     String          @default("")
  price           Float           @default(0)
  priceBs         Float           @default(0)
  status          String          @default("upcoming")
  maxParticipants Int             @default(500)
  featured        Boolean         @default(false)
  organizer       String          @default("")
  prizes          String          @default("")
  rules           String          @default("")
  kitInfo         String          @default("")
  sponsors        String          @default("")
  categories      String          @default("")
  ageCalcMode     String          @default("calendar_year")
  categoryInterval String          @default("10")
  hasShirt        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  registrations   Registration[]
  products        Product[]
  extras          EventExtra[]
}

model Registration {
  id               String   @id @default(cuid())
  eventId          String
  event            Event    @relation(fields: [eventId], references: [id])
  firstName        String
  lastName         String
  email            String
  phone            String
  idNumber         String   @default("")
  gender           String
  dateOfBirth      String
  shirtSize        String   @default("")
  category         String
  team             String   @default("")
  emergencyContact String   @default("")
  emergencyPhone   String   @default("")
  paymentMethod    String   @default("")
  paymentRef       String   @default("")
  status           String   @default("pending")
  waiverAccepted   Boolean  @default(false)
  bibNumber        Int?
  createdAt        DateTime @default(now())
  regExtras        RegistrationExtra[]
}

model EventExtra {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  name      String
  price     Float    @default(0)
  hasSizes  Boolean  @default(false)
  sizes     String   @default("[]")
  included  Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  regExtras  RegistrationExtra[]
}

model RegistrationExtra {
  id              String     @id @default(cuid())
  registrationId  String
  registration    Registration @relation(fields: [registrationId], references: [id])
  eventExtraId    String
  eventExtra      EventExtra  @relation(fields: [eventExtraId], references: [id])
  selectedSize    String     @default("")
}

model Product {
  id          String   @id @default(cuid())
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id])
  name        String
  description String   @default("")
  price       Float    @default(0)
  priceBs     Float    @default(0)
  imageUrl    String   @default("")
  images      String   @default("[]")
  sizes       String   @default("[]")
  color       String   @default("")
  stock       Int      @default(0)
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      ProductOrder[]
}

model ProductOrder {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  firstName     String
  lastName      String
  email         String
  phone         String
  idNumber      String   @default("")
  size          String   @default("")
  color         String   @default("")
  quantity      Int      @default(1)
  totalPrice    Float    @default(0)
  totalPriceBs  Float    @default(0)
  paymentMethod String   @default("")
  paymentRef    String   @default("")
  status        String   @default("pending")
  notes         String   @default("")
  createdAt     DateTime @default(now())
}
